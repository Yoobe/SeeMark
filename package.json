{
  "name": "see-mark",
  "displayName": "SeeMark",
  "description": "Live markdown rendering for the basics that makes a Markdown way easier to visually parse as you work on it. Hides syntax when not editing, shows full markdown when focused.",
  "version": "0.2.0",
  "publisher": "jonahgoldsaito",
  "icon": "icon.png",
  "keywords": ["markdown", "preview", "wysiwyg", "editing", "live"],
  "repository": {
    "type": "git",
    "url": "https://github.com/jonahgoldsaito/MarkGetsDown.git"
  },
  "homepage": "https://github.com/jonahgoldsaito/MarkGetsDown",
  "bugs": {
    "url": "https://github.com/jonahgoldsaito/MarkGetsDown/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
  "commands": [
    { "command": "SeeMark.toggle", "title": "Toggle SeeMark" },
    { "command": "SeeMark.enable", "title": "Enable SeeMark" },
    { "command": "SeeMark.disable", "title": "Disable SeeMark" }
  ],
  "configuration": {
    "title": "SeeMark",
    "properties": {
      "seeMark.headerColor": {
        "type": "string",
        "default": "#8b949e",
        "description": "Heading color for rendered markdown headings."
      },
      "seeMark.h1Scale": {
        "type": "number",
        "default": 1.8,
        "description": "Font scale for H1."
      },
      "seeMark.h2Scale": {
        "type": "number",
        "default": 1.45,
        "description": "Font scale for H2."
      },
      "seeMark.h3Scale": {
        "type": "number",
        "default": 1.2,
        "description": "Font scale for H3."
      },
      "seeMark.inlineCodeBorderRadius": {
        "type": "string",
        "default": "5px",
        "description": "Border radius for inline code."
      },
      "seeMark.inlineCodeBorderColor": {
        "type": "string",
        "default": "rgba(127,127,127,0.22)",
        "description": "Border color for inline code."
      },
      "seeMark.bulletMarker": {
        "type": "string",
        "default": "•",
        "description": "Marker used for bullet lists."
      },
      "seeMark.hideMarkdownSyntax": {
        "type": "boolean",
        "default": true,
        "description": "Hide markdown syntax when a line is not focused."
      }
    }
  }
}
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "echo 'No linter configured'",
    "package": "vsce package --out see-mark.vsix",
    "install-local": "code --install-extension see-mark.vsix --force",
    "deploy": "npm run package && npm run install-local"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.5",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "marked": "^12.0.2"
  }
}


