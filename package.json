{
  "name": "see-mark",
  "displayName": "SeeMark",
  "description": "Live markdown rendering for the basics that makes a Markdown way easier to visually parse as you work on it. Hides syntax when not editing, shows full markdown when focused.",
  "version": "0.1.0",
  "publisher": "jonahgoldsaito",
  "icon": "icon.png",
  "keywords": ["markdown", "preview", "wysiwyg", "editing", "live"],
  "repository": {
    "type": "git",
    "url": "https://github.com/jonahgoldsaito/MarkGetsDown.git"
  },
  "homepage": "https://github.com/jonahgoldsaito/MarkGetsDown",
  "bugs": {
    "url": "https://github.com/jonahgoldsaito/MarkGetsDown/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "SeeMark.toggle",
        "title": "Toggle SeeMark"
      },
      {
        "command": "SeeMark.enable",
        "title": "Enable SeeMark"
      },
      {
        "command": "SeeMark.disable",
        "title": "Disable SeeMark"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "echo 'No linter configured'",
    "package": "vsce package --out see-mark.vsix",
    "install-local": "code --install-extension see-mark.vsix --force",
    "deploy": "npm run package && npm run install-local"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.5",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "marked": "^12.0.2"
  }
}


